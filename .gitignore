# Claude Code local settings
.claude/

# Personal config (contains local paths) — use config.toml.example as the template
config.toml
# Per-machine overlay applied on top of config.toml (paths, music_dir,
# path_remap differ between hosts). Never shared between machines.
# The .example variants ARE committed (templates); the deployed copies
# (with real paths) are not.
config.local.toml
config.local.toml.linux
config.local.toml.windows

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
dist/
*.egg-info/

# AutoDJ generated files
index/
models/

# Editor
.vscode/
.idea/
*.swp

# Test temp files
tmp/

# Runtime web-UI snapshots (saved by the browser via "View page source")
served.html

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Coverage
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Playwright audit infra — devs run `npm i -D @playwright/test` themselves
node_modules/
package-lock.json
# Audit reports may contain LAN paths / track metadata
*_audit.json
*_audit_report.json
.playwright-mcp/

# Vite build output -- regenerated by `npm run build`.  Server falls
# back to src/autodj/static/ when this directory is missing so dev
# users without Node still get a working site.
src/autodj/static_dist/
