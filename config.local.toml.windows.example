# Per-machine overlay applied on top of config.toml at load time.
# Copy this file to `config.local.toml` on your Windows host and adjust
# the paths to match your mapped drive / library locations.
#
# This file is NOT shared between machines — `config.local.toml` is
# gitignored.  Each host keeps its own.

[library]
# Where the beets-relative paths in tracks.db are anchored.
# On Windows, ALWAYS use forward slashes — TOML treats backslashes as
# escape sequences and "C:\Users" will fail to parse.
music_dir = "Z:/Beetsmusic"

# Path to the beets SQLite database on this host.
beets_db = "Z:/library.db"

# Optional cross-OS bridge for absolute paths from another machine.
# Useful if your library.db came from a Linux host with absolute paths
# that don't resolve under Z:.  Once `autodj prune` rewrites paths to
# relative form, this remap is no longer needed.
# path_remap = [
#     ["/mnt/music/", "Z:/Beetsmusic/"],
# ]
